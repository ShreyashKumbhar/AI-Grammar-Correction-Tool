{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "LanguageTool": {
    "BaseUrl": "https://api.languagetool.org",
    "Endpoint": "/v2/check",
    "DefaultLanguage": "en-US",
    "EnabledCategories": "TYPOS,GRAMMAR,STYLE",
    "TimeoutSeconds": 15
  }
}
