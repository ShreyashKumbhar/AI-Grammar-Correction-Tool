{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=(localdb)\\mssqllocaldb;Database=GrammarCorrectorDb;Integrated Security=true;TrustServerCertificate=true;"
  },
  "Jwt": {
    "SecretKey": "your-super-secret-key-change-this-in-production-minimum-32-characters-long!",
    "Issuer": "GrammarCorrector",
    "Audience": "GrammarCorrectorUsers",
    "ExpirationMinutes": 1440
  },
  "Razorpay": {
    "KeyId": "rzp_test_your_key_id_here",
    "KeySecret": "your_razorpay_key_secret_here",
    "WebhookSecret": "your_razorpay_webhook_secret_here"
  },
  "LanguageTool": {
    "BaseUrl": "https://api.languagetool.org",
    "Endpoint": "/v2/check",
    "DefaultLanguage": "en-US",
    "EnabledCategories": "TYPOS,GRAMMAR,STYLE",
    "TimeoutSeconds": 15
  }
}
